{
  "name": "quasar-agent",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "tsx packages/cli/src/index.ts start",
    "init:config": "tsx packages/cli/src/index.ts setup",
    "model": "tsx packages/cli/src/index.ts model",
    "dev": "tsx watch packages/cli/src/index.ts start",
    "typecheck": "tsc --noEmit",
    "doctor": "tsx scripts/doctor.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "vitest": "^3.1.0"
  }
}
